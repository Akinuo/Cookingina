# ─── CookingINA Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Run: cp .env.example .env
# NEVER commit .env to git — it is in .gitignore already.

# ── AI Proxy (Cloudflare Worker) ────────────────────────────────────────────
# Used for: AI Recipe Generation, Cooking Assistant, Price Checker, Meal Planner
# Do NOT put your Groq key here — it lives server-side as a Worker secret.
# See worker/README.md to deploy the proxy (free, ~5 min, no credit card).
VITE_GROQ_PROXY_URL=https://cookingina-groq-proxy.your-subdomain.workers.dev

# ── Firebase (https://console.firebase.google.com) ─────────────────────────────
# Used for: Google Authentication, Firestore database, Hosting
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=AIza_your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ── Cloudinary (https://cloudinary.com) ────────────────────────────────────────
# Used for: Profile photo uploads, Recipe image uploads, Community post images
# Free tier: 25GB storage + 25GB bandwidth/month — no credit card needed
# Get these from: Cloudinary Console → Settings → Upload → Upload Presets
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=cookingina_unsigned
